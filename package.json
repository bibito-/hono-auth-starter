{
  "name": "hono-auth-starter",
  "type": "module",
  "scripts": {
    "dev:cfw": "vite --port 5173 --strictPort",
    "dev:spa": "VERCEL=1 vite --port 5174 --strictPort",
    "dev:clean": "fuser -k 5173/tcp 5174/tcp 2>/dev/null; true",
    "deploy": "vite build && wrangler deploy --config dist/hono_auth_starter/wrangler.json --minify",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings",
    "types:supabase": "supabase gen types typescript --linked > src/shared/types/database.types.ts",
    "test": "vitest"
  },
